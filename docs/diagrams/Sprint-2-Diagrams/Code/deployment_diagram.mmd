
graph TB
    %% Nodes
    node1["Developer PC\n(Windows/Mac/Linux)"]
    
    subgraph LocalHost ["Local Machine (localhost)"]
        
        subgraph DockerEngine ["Docker Desktop Runtime"]
            
            subgraph AppGroup ["Application Stack"]
                Frontend["Frontend Container\n(Next.js Dev Server)"]
                Backend["Backend Container\n(FastAPI + Uvicorn)"]
            end
            
            subgraph DataGroup ["Data Services"]
                DB[("PostgreSQL 15\n(Volume: ./data/db)")]
                Redis[("Redis Cache\n(Volume: ./data/cache)")]
                Sonar[("SonarQube\n(Code Analysis)")]
            end
        end
    end
    
    %% Connections
    node1 -->|"Browser: http://localhost:3000"| Frontend
    node1 -->|"Browser/Postman: http://localhost:8000"| Backend
    node1 -->|"Admin: http://localhost:9000"| Sonar
    
    Frontend -->|"Internal Network: http://backend:8000"| Backend
    Backend -->|"Internal Network: tcp://postgres:5432"| DB
    Backend -->|"Internal Network: tcp://redis:6379"| Redis
    
    %% Styles
    style node1 fill:#e1f5fe,stroke:#01579b
    style LocalHost fill:#f5f5f5,stroke:#616161
    style DockerEngine fill:#e3f2fd,stroke:#1565c0
    style AppGroup fill:#e8f5e9,stroke:#2e7d32
    style DataGroup fill:#fff3e0,stroke:#e65100
