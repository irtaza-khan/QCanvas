%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '20px', 'fontFamily': 'arial', 'clusterBkg': '#fafafa', 'clusterBorder': '#666'}}}%%
flowchart TB
    %% Styling Definitions
    classDef container fill:#fff,stroke:#333,stroke-width:2px;
    classDef component fill:#e3f2fd,stroke:#1565c0,stroke-width:1px;
    classDef infra fill:#f1f8e9,stroke:#558b2f,stroke-width:1px;
    classDef data fill:#fff3e0,stroke:#e65100,stroke-width:1px;

    subgraph Frontend_Tier ["Frontend Tier (Client)"]
        direction TB
        NextJS["Next.js App\n(React 18 + TS)"]:::component
        Zustand["Zustand Store\n(State Mgmt)"]:::component
        Monaco["Monaco Editor\n(Code/QASM)"]:::component
        
        NextJS --> Zustand
        NextJS --> Monaco & Shadcn["UI Components"]:::component
        Zustand --> Monaco
    end

    subgraph Infrastructure_Tier ["Dockerized Infrastructure"]
        direction TB
        NGINX["Nginx Gateway\n(Port 80/443)"]:::infra
        
        subgraph Backend ["Backend Container (FastAPI)"]
            direction TB
            FastAPI["FastAPI Server"]:::infra
            
            %% Flattened Internal Logic for Compactness
            Middleware["Middleware Stack\n(Auth, CORS, RateLimit)"]:::infra
            Services["App Services\n(Conversion, Simulation, Projects)"]:::infra
            
            subgraph Engine ["Quantum Engine"]
                Converters["Converters\n(AST Parsing)"]:::infra
                QSim["QSim Simulator\n(Statevector)"]:::infra
                Sandbox["Hybrid Sandbox"]:::infra
            end
            
            FastAPI --> Middleware --> Services
            Services --> Converters
            Services --> QSim
            Services --> Sandbox --> QSim
        end
        
        subgraph Data_Tier ["Data Persistence"]
            Postgres[("PostgreSQL 15")]:::data
            Redis[("Redis Cache")]:::data
        end
        
        SonarQube["SonarQube"]:::infra
    end

    %% Optimized Connections
    NextJS ===> NGINX
    NGINX --> FastAPI
    
    Services -.-> Postgres
    Services -.-> Redis

