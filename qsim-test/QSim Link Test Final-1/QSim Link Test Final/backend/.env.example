# FastQSim Credentials
FASTQUBIT_USER_ID=your-user-id-here
# Optional alias (same as FASTQUBIT_USER_ID) used in some FastQubit demos
# FASTQUBIT_END_USER_ID=your-user-id-here
FASTQUBIT_SESSION_TOKEN=your-session-token-here   # usually starts with fqp_
# Backward-compatible alias (optional; the app maps this to FASTQUBIT_SESSION_TOKEN)
FASTQSIM_API_TOKEN=your-api-token-here
# Optional alias (same as FASTQSIM_API_TOKEN) — integrator key fqi_...
# FASTQUBIT_INTEGRATOR_KEY=your-api-token-here

# Optional Settings
FASTQUBIT_ENDPOINT=https://api.qsim.io
FASTQSIM_EXECUTION_MODE=cloud

# Kernel WebSocket (server-side /api/kernel/execute) — only if the gateway rejects TLS or checks Origin
# FASTQUBIT_WS_INSECURE_SSL=1
# FASTQUBIT_WS_ORIGIN=https://fastqubit.dev
