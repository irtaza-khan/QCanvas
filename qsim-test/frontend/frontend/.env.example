# Use host only (NO trailing /api)
VITE_API_PROXY_TARGET=https://fastqubit.dev

# Explicit local dev base. Keep /api so Vite proxy handles ELB calls without CORS.
VITE_API_BASE_URL_DEV=/api

# Public API base used in production builds and as a dev fallback.
VITE_API_BASE_URL=https://fastqubit.dev/api
