# AWS credentials and region (used when provider is "aws")
# Copy to .env and fill in. Never commit .env.
#
# On Windows: same format (no "set" prefix). The app loads .env automatically.
# To create .env from this file:  powershell -File scripts\set_aws_env.ps1 -CreateEnv
#
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1

# Optional convenience variable (applies to all agents unless overridden):
#BEDROCK_INFERENCE_PROFILE_ARN=

# Per-agent inference profile ARNs (recommended when you have different ARNs per agent):
BEDROCK_INFERENCE_PROFILE_ARN_DESIGNER=
BEDROCK_INFERENCE_PROFILE_ARN_OPTIMIZER=
BEDROCK_INFERENCE_PROFILE_ARN_VALIDATOR=
BEDROCK_INFERENCE_PROFILE_ARN_EDUCATIONAL=