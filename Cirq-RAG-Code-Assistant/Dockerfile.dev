# Cirq-RAG-Code-Assistant: development image.
#
# Installs the full dev bundle (torch, sentence-transformers, FAISS, test
# tooling, etc.) and runs uvicorn with --reload. Intended for use via
# docker-compose.yml (the dev file) which also bind-mounts the source tree.

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential curl libpq5 \
    && rm -rf /var/lib/apt/lists/*

# Dev image installs the full stack (requirements-dev.txt transitively
# includes requirements-local.txt and requirements-base.txt).
COPY requirements-base.txt requirements-local.txt requirements-dev.txt ./
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements-dev.txt

COPY . .

EXPOSE 8000

CMD ["uvicorn", "src.server:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
