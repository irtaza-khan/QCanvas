## QCanvas (Docker Compose) - example environment
#
# Copy to `.env` (do not commit `.env`) and adjust values as needed.
#
# The frontend stays local and should keep:
#   NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
#
# The backend container connects to Postgres/Redis via Compose DNS names.

# --- Postgres (service: postgres) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qcanvas_db

# These are used by backend/app/config/settings.py to build DATABASE_URL
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432

# --- Redis (service: redis) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Security ---
# Change this in real deployments.
SECRET_KEY=development_secret_key

# Optional: override full URLs directly if you prefer (takes precedence if app uses it)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/qcanvas_db
# REDIS_URL=redis://redis:6379/0
