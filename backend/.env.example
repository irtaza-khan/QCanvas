# Local DB URL Example
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/qcanvas_db

# AWS RDS DB URL (Replace with your actual DB URL)
DATABASE_URL=postgresql://<USERNAME>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>

# OTP Setup
AUTH_EMAIL_OTP_ENABLED=true
OTP_PEPPER=your_secret_pepper_string_here
RESEND_API_KEY=your_resend_api_key_here

# Email provider setup
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=QCanvas
EMAIL_FROM_ADDRESS=security@qcanvas.codes
RESEND_API_BASE_URL=https://api.resend.com

# FastQSim Online Mode Configuration
FASTQSIM_ONLINE_MODE=true
FASTQUBIT_USER_ID=12345678
FASTQSIM_API_TOKEN=your_token_here
FASTQUBIT_ENDPOINT=https://fastqubit.dev/api
FASTQSIM_EXECUTION_MODE=cloud

